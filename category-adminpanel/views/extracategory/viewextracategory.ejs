<%- include('../header') %>

<!-- Main Page Wrapper --> 
<div class="d-flex flex-column" style="min-height:100vh;">
    <!-- Main Content Area -->
    <div class="flex-grow-1 d-flex flex-column justify-content-center">
        <div class="page-wrapper">
            <!-- Page Breadcrumb -->
            <div class="page-breadcrumb">
                <div class="row">
                    <div class="col-12 d-flex no-block align-items-center">
                        <h4 class="page-title text-white">Extra Category List</h4>
                        <div class="ms-auto text-end">
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb bg-transparent">
                                    <li class="breadcrumb-item"><a href="/" style="color: #ffe">Home</a></li>
                                    <li class="breadcrumb-item active" aria-current="page" style="color: #ffe">Extra Category</li>
                                </ol>
                            </nav>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Main Table Section -->
            <div class="container d-flex justify-content-center align-items-center" style="min-height: 70vh;">
                <div class="col-12 col-sm-10 col-md-9 col-lg-8">
                    <div class="card shadow rounded" style="border-radius:15px;">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <h3 class="card-title font-weight-bold text-primary">Extra Category List</h3>
                                <a href="/extracategory/addextracategory" class="btn btn-success rounded-pill px-4 py-2 font-weight-bold">
                                    + Add Extra Category
                                </a>
                            </div>
                            <div class="table-responsive mt-3">
                                <table class="table table-hover table-bordered rounded">
                                    <thead class="table-light">
                                        <tr>
                                            <th>#</th>
                                            <th>Category</th>
                                            <th>SubCategory</th>
                                            <th>ExtraCategory Title</th>
                                            <th class="text-center">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% allExtraCategory.map((data, index) => { %>
                                            <tr>
                                                <td><%= index + 1 %></td>
                                                <td><%= data.category_id ? data.category_id.c_title : 'N/A' %></td>
                                                <td><%= data.subCategory_id ? data.subCategory_id.subcategory_title : 'N/A' %></td>
                                                <td><%= data.extraCategory_title %></td>
                                                <td class="text-center">
                                                    <a href="/extracategory/updateextracategory/<%= data.id %>" class="btn btn-success rounded-pill px-3 py-1">Edit</a>
                                                    <a href="/extracategory/deletextracategory/<%= data.id %>" class="btn btn-danger rounded-pill px-3 py-1"
                                                       onClick="return confirm('Are you sure you want to delete this item?')">Delete</a>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>                
                        </div>
                    </div>
                </div>
            </div>            
        </div>
    </div>

    <!-- Footer Part -->
    <div>
        <%- include('../footer') %>
    </div>
</div>
