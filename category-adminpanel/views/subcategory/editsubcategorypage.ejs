<%- include('../header') %>

<div class="page-wrapper d-flex align-items-center justify-content-center" style="min-height: calc(100vh - 100px);">
  <div class="container-fluid">
    <div class="row justify-content-center">
      <div class="col-md-8">
        <div class="card">
          <form class="form-horizontal" method="post" action="/subcategory/updateSubCategory/<%= updateSubCategory.id %>">
            <div class="card-body">
              <h4 class="card-title text-center mb-4">Update SubCategory</h4>

              <!-- Category Dropdown -->
              <div class="form-group row">
                <label class="col-sm-3 text-end control-label col-form-label">Category</label>
                <div class="col-sm-9">
                  <select class="form-control" name="category_id" required>
                    <option value="">--- Select ---</option>
                    <% allCategory.map((category) => { %>
                      <option value="<%= category.id %>" <% if(category.id == updateSubCategory.category_id) { %> selected <% } %> >
                        <%= category.c_title %>
                      </option>
                    <% }) %>
                  </select>
                </div>
              </div>

              <!-- SubCategory Title -->
              <div class="form-group row">
                <label class="col-sm-3 text-end control-label col-form-label">SubCategory Title</label>
                <div class="col-sm-9">
                  <input type="text" class="form-control" name="subcategory_title"
                         value="<%= updateSubCategory.subcategory_title %>"
                         placeholder="Enter Sub Category Title" required />
                </div>
              </div>
            </div>

            <!-- Submit Button -->
            <div class="border-top">
              <div class="card-body text-center">
                <button type="submit" class="btn btn-primary px-4">Update Sub Category</button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../footer') %>
