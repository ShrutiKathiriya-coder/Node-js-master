<%- include('../header')%>

<!-- Page Wrapper -->
<div class="page-wrapper d-flex flex-column justify-content-center align-items-center" style="min-height:100vh;">

  <!-- Category Table Section -->
  <div class="container-fluid d-flex justify-content-center mt-5">
    <div class="col-12 col-md-10 col-lg-8">
      <div class="card shadow border-0">
        <div class="card-body px-4 py-4">
          <h4 class="text-center fw-bold text-dark mb-4">Category List</h4>

          <div class="table-responsive">
            <table class="table table-bordered table-hover text-center align-middle mb-0">
              <thead class="table-dark">
                <tr>
                  <th>#</th>
                  <th>Category Title</th>
                  <th>Image</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% records.map((data, index) => { %>
                  <tr>
                    <td><%= index + 1 %></td>
                    <td class="fw-semibold"><%= data.c_title %></td>
                    <td>
                      <img src="/<%= data.c_image %>" alt="Category Image" class="img-fluid border" style="height: 80px; width: 80px; object-fit: cover;">
                    </td>
                    <td>
                      <div class="d-flex justify-content-center gap-2">
                        <a href="/category/editCategoryPage/<%= data.id %>" class="btn btn-success btn-sm">Edit</a>
                        <a href="/category/deleteCategory/<%= data.id %>" class="btn btn-danger btn-sm">Delete</a>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

        </div>
      </div>
    </div>
  </div>

</div>

<%- include('../footer') %>
