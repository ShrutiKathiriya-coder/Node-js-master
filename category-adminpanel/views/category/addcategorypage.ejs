<%- include('../header') %>

<!-- Main Page Wrapper -->
<div class="page-wrapper" style="min-height:100vh;">
    <div class="page-breadcrumb">
        <div class="row">
            <div class="col-12 d-flex no-block align-items-center">
                <h4 class="page-title text-white">Category Form</h4>
                <div class="ms-auto text-end">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb bg-transparent">
                            <li class="breadcrumb-item"><a href="/" style="color: #ffe">Home</a></li>
                            <li class="breadcrumb-item active" aria-current="page" style="color: #ffe">Add Category</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>
    </div>

    <!-- Form Container -->
    <div class="container d-flex justify-content-center align-items-center" style="min-height: 70vh;">
        <div class="col-12 col-sm-8 col-md-6">
            <div class="card shadow rounded" style="border-radius:15px;">
                <form method="POST" action="/category/insertCategory" enctype="multipart/form-data">
                    <div class="card-body p-4">
                        <h3 class="card-title text-center font-weight-bold text-primary">Add New Category</h3>
                        
                        <!-- Category Title -->
                        <div class="form-group row mt-3">
                            <label class="col-sm-4 col-form-label font-weight-bold text-end">Category Title</label>
                            <div class="col-sm-8">
                                <input 
                                    type="text" 
                                    class="form-control rounded-pill" 
                                    name="c_title" 
                                    placeholder="Enter Category Title" 
                                    required 
                                    style="border:1px solid #ccc;" 
                                />
                            </div>
                        </div>

                        <!-- Category Image -->
                        <div class="form-group row mt-3">
                            <label class="col-sm-4 col-form-label font-weight-bold text-end">Category Image</label>
                            <div class="col-sm-8">
                                <div class="custom-file">
                                    <input 
                                        type="file" 
                                        class="form-control rounded-pill" 
                                        name="c_image" 
                                        id="validatedCustomFile" 
                                        required 
                                        style="border:1px solid #ccc;" 
                                    />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="border-top p-3 text-center">
                        <button 
                            type="submit" 
                            class="btn btn-success rounded-pill px-5 py-2 font-weight-bold" 
                            style="transition: all 0.3s;"
                        >
                            Add Category
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>  
</div>

<%- include('../footer') %>
