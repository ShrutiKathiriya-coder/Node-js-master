<%- include('../header') %>

<div class="page-wrapper" style="min-height:100vh; background: linear-gradient(135deg, #ffffff, #764ba2)">

    <div class="page-breadcrumb mb-3">
        <div class="row">
            <div class="col-12 d-flex align-items-center justify-content-between">
                <h4 class="page-title">Edit Category</h4>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a href="#">Home</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Edit Category</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>

    <div class="container-fluid d-flex justify-content-center align-items-center" style="min-height: 75vh;">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-4">
                <form method="post" action="/category/updateCategory/<%= data.id %>" enctype="multipart/form-data">
                    <div class="card-body px-5 py-4">
                        <h4 class="card-title text-center mb-4 fw-bold text-primary">Edit Category</h4>

                        <!-- Category Title -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Category Title</label>
                            <input type="text" class="form-control rounded-pill px-4 py-2" name="c_title" value="<%= data.c_title %>" placeholder="Enter Category Title" required>
                        </div>

                        <!-- Image Upload -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Upload New Image</label>
                            <input type="file" class="form-control rounded-pill px-4 py-2" name="c_image">
                        </div>

                        <!-- Existing Image -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Current Image</label><br>
                            <img src="/<%= data.c_image %>" alt="Current Image" height="100" class="border rounded">
                        </div>

                        <!-- Submit -->
                        <div class="text-center">
                            <button type="submit" class="btn btn-primary px-5 py-2 rounded-pill shadow-sm">Update Category</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('../footer') %>
